# Kick OAuth app — register at https://kick.com/settings/developer
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# Must exactly match the redirect URI configured on the Kick app
KICK_REDIRECT_URI=https://your-domain.example/api/auth/callback

# Long random string used to sign session + OAuth-state cookies
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# Upstash Redis (Vercel Marketplace > Upstash, or upstash.com) — REST API credentials
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Shared secret required to run the one-time webhook subscription setup
# (visit /api/admin/subscribe?secret=<this value> once, see README)
ADMIN_SECRET=

# Set to "true" only for local debugging to skip Kick webhook signature checks
KICK_SKIP_WEBHOOK_VERIFICATION=false
